{
  "expo": {
    "name": "Baza.ng",
    "slug": "baza-ng",
    "version": "2.7.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bazang",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "7",
      "bundleIdentifier": "com.baza.mobile",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDisplayName": "Baza.ng",
        "CFBundleName": "Baza.ng",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 7,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.baza.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.30504101922-hsleh13ueea8ve44nbndq7q3t9s9bjp0"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6c24701d-c200-450a-ac6a-80f75d455778"
      }
    }
  }
}
